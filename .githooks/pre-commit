#!/bin/sh
set -eu

echo "==> gofmt"
files="$(gofmt -l .)"
if [ -n "$files" ]; then
  echo "$files"
  echo "run: gofmt -w <files>"
  exit 1
fi

echo "==> go mod tidy"
go mod tidy -diff

echo "==> go vet"
go vet ./...

echo "==> golangci-lint"
go run github.com/golangci/golangci-lint/v2/cmd/golangci-lint@v2.12.2 run

echo "==> go test"
go test ./...
